{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    /* Use NodeNext for modern package resolution */
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",

    "lib": ["ES2022"],
    "types": ["node"],

    /* Necessary for importing CommonJS like dotenv */
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "skipLibCheck": true
  }
}